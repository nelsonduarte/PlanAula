{
  "name": "planaula",
  "version": "1.0.0",
  "description": "Planeador de Aulas para Professores",
  "homepage": "https://github.com/nelsonduarte/PlanAula#readme",
  "bugs": {
    "url": "https://github.com/nelsonduarte/PlanAula/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nelsonduarte/PlanAula.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "run:app": "node scripts/run.mjs",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "electron-squirrel-startup": "^1.0.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.planaula.app",
    "productName": "PlanAula",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "app/node_modules/better-sqlite3/build/Release",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
