{
  "name": "planaula",
  "version": "1.0.0",
  "description": "Planeador de Aulas para Professores",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "run:app": "node scripts/run.js",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "electron-squirrel-startup": "^1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.5",
    "wait-on": "^7.2.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.planaula.app",
    "productName": "PlanAula",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "app/node_modules/better-sqlite3/build/Release",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
